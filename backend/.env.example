# ── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./joi_app.db

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por comas (pydantic-settings la parsea como JSON array)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── LLM — API Keys (todas opcionales; sólo se necesita la del proveedor usado)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── LLM — Modelos por propósito ──────────────────────────────────────────────
# Formato LiteLLM: "anthropic/claude-sonnet-4-6", "gpt-4o", "gemini/gemini-pro", etc.
LLM_MODEL_SQL=anthropic/claude-haiku-4-5-20251001
LLM_MODEL_JSON=anthropic/claude-haiku-4-5-20251001

# ── Data Agent — comportamiento ───────────────────────────────────────────────
RAG_DEFAULT_ENABLED=true
QUERY_TIMEOUT_SECONDS=10
MAX_ROWS_PER_EXTRACTION=1000
TRACE_PREVIEW_ROWS=10

# ── Uploads ────────────────────────────────────────────────────────────────────
JSON_UPLOAD_MAX_BYTES=10485760
